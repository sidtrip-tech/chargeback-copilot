APP_ENV=development
HOST=127.0.0.1
PORT=8010
# Local default:
DATABASE_URL=sqlite:///backend/chargeback_copilot.db
# Production target:
# DATABASE_URL=postgresql://user:password@host:5432/chargeback_copilot
SEED_DEMO_DATA=true
AUTH_SECRET=replace-with-a-secure-secret
SESSION_COOKIE_NAME=chargeback_copilot_session
CSRF_COOKIE_NAME=chargeback_copilot_csrf
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8010,http://localhost:8010
PUBLIC_BASE_URL=http://127.0.0.1:8010
MAX_JSON_BODY_BYTES=65536
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Optional email delivery for verification and password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Production evidence storage
OBJECT_STORAGE_BACKEND=local
EVIDENCE_UPLOAD_DIR=backend/uploads
MAX_UPLOAD_BYTES=8388608
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# Future production processing
VIRUS_SCAN_ENABLED=false
VIRUS_SCAN_MODE=basic
PDF_EXPORT_ENABLED=false

# Optional AI drafting
OPENAI_API_KEY=
OPENAI_MODEL=

# Monitoring
SENTRY_DSN=
